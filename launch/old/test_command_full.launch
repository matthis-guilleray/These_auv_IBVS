<?xml version="1.0" encoding="UTF-8"?>
<launch>	
	<group> 
	
		<include file="$(find-pkg-share IBVS_ROV)/launch/run_mavros.launch">  
			<arg name="namespace" value="bluerov2"/>		
		</include>
		<include file="$(find-pkg-share IBVS_ROV)/launch/run_gamepad.launch">  
			<arg name="namespace" value="bluerov2"/>	
		</include>
		
	</group>

	<group>
        <node pkg="IBVS_ROV" exec="Image_Select" name="Image_selector" namespace="$(var namespace)" output="screen"></node>
		<node pkg="IBVS_ROV" exec="Image_Track" name="Image_tracking" namespace="$(var namespace)" output="screen"></node>
        <node pkg="IBVS_ROV" exec="Image_VideoGrabber" name="VideoGrabber" namespace="$(var namespace)" output="screen"></node>

        <node pkg="IBVS_ROV" exec="Controller_camera" name="Controller_camera" namespace="$(var namespace)" output="screen"></node>
        <node pkg="IBVS_ROV" exec="Controller_frame" name="Controller_frame" namespace="$(var namespace)" output="screen"></node>

        <node pkg="IBVS_ROV" exec="Tester_Command_IBVS" name="BlueRov" namespace="$(var namespace)" output="screen"></node>
	</group>
		
</launch>	
