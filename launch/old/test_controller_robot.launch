<?xml version="1.0" encoding="UTF-8"?>
<launch>	

	<group>
		<node pkg="IBVS_ROV" exec="Image_VideoGrabber" name="VideoGrabber" output="screen"></node>
		<node pkg="IBVS_ROV" exec="Tester_Base" name="BlueRov" output="screen"></node>


        <node pkg="IBVS_ROV" exec="Image_Select" name="Image_selector" output="screen"></node>
		<node pkg="IBVS_ROV" exec="Image_Track" name="Image_tracking" output="screen"></node>

        <node pkg="IBVS_ROV" exec="Controller_Camera" name="Controller_camera" output="screen"></node>
        <node pkg="IBVS_ROV" exec="Controller_Frame" name="Controller_frame" output="screen"></node>

	</group>
		
</launch>	
